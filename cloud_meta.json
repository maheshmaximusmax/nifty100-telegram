// ══════════════════════════════════════════════
// FIX 1: CSV UPLOAD — triggerCSVPick + loadCSV
// ══════════════════════════════════════════════

// REPLACE your existing triggerCSVPick() function with this:
function triggerCSVPick() {
  const inp = document.getElementById('csvf');
  if (!inp) return;
  // Reset value so same file can be picked again
  inp.value = '';
  inp.click();
}

// REPLACE your existing loadCSV() function with this:
function loadCSV(event) {
  const file = event && event.target && event.target.files && event.target.files[0];
  if (!file) {
    toast('❌ No file selected', 'red');
    return;
  }
  if (!file.name.endsWith('.csv')) {
    toast('❌ Please select a .csv file', 'red');
    return;
  }

  // Show loading state
  const filelbl = document.getElementById('filelbl');
  if (filelbl) filelbl.textContent = 'Loading ' + file.name + '...';
  toast('📂 Loading CSV...', 'blue');

  const reader = new FileReader();

  reader.onload = function(e) {
    try {
      const text = e.target.result;
      if (!text || !text.trim()) {
        toast('❌ File is empty', 'red');
        if (filelbl) filelbl.textContent = 'File is empty';
        return;
      }

      // Use PapaParse to parse the CSV
      Papa.parse(text, {
        header: true,
        skipEmptyLines: true,
        complete: function(results) {
          if (!results.data || results.data.length === 0) {
            toast('❌ CSV has no data rows', 'red');
            if (filelbl) filelbl.textContent = 'No data found in file';
            return;
          }

          allRows = results.data;
          allCols = results.meta.fields || Object.keys(allRows[0] || {});

          // Update file label
          if (filelbl) filelbl.textContent = file.name + ' (' + allRows.length + ' stocks)';
          toast('✅ Loaded ' + allRows.length + ' stocks from ' + file.name, 'green');

          // Show analysis section
          const nodata = document.getElementById('nodata');
          const adata = document.getElementById('adata');
          if (nodata) nodata.style.display = 'none';
          if (adata) adata.style.display = 'block';

          // Render everything
          renderStats();
          renderCharts();
          renderTable(allRows);
          renderRiskSel();
          renderMovers();
          renderSavedFilters();
        },
        error: function(err) {
          toast('❌ CSV parse error: ' + (err.message || err), 'red');
          if (filelbl) filelbl.textContent = 'Parse error — check file format';
        }
      });
    } catch (err) {
      toast('❌ Error reading file: ' + err.message, 'red');
      if (filelbl) filelbl.textContent = 'Read error';
    }
  };

  reader.onerror = function() {
    toast('❌ Failed to read file. Try again.', 'red');
    if (filelbl) filelbl.textContent = 'File read failed';
  };

  reader.readAsText(file);
}


// ══════════════════════════════════════════════
// FIX 2: AUTO-SCHEDULE — applySchedule()
// Updates the cron line inside the workflow .yml file on GitHub
// ══════════════════════════════════════════════

// REPLACE your existing applySchedule() function with this:
async function applySchedule() {
  const gh = getGH();
  if (!gh.user || !gh.repo || !gh.token) {
    toast('⚠️ Configure GitHub settings first', 'yellow');
    pg('settings', null);
    setTimeout(() => stab('github', null), 100);
    return;
  }

  // Build the cron string
  const cron = document.getElementById('cron-val').textContent.replace(/\\/g, '');
  if (!cron || cron === '—') {
    toast('❌ Invalid cron value. Set schedule first.', 'red');
    return;
  }

  const log = document.getElementById('actlog');
  if (log) log.textContent = '⏳ Applying schedule "' + cron + '" to workflow file...';

  const headers = {
    'Authorization': 'token ' + gh.token,
    'Accept': 'application/vnd.github+json',
    'X-GitHub-Api-Version': '2022-11-28',
    'Content-Type': 'application/json'
  };

  const filePath = '.github/workflows/nifty100.yml';
  const apiUrl = 'https://api.github.com/repos/' + gh.user + '/' + gh.repo + '/contents/' + filePath;

  try {
    // Step 1: Get current file + sha
    const getResp = await fetch(apiUrl, { headers });
    if (!getResp.ok) {
      const err = await getResp.json();
      toast('❌ Cannot read workflow file: ' + (err.message || getResp.status), 'red');
      if (log) log.textContent = '❌ Error: ' + (err.message || getResp.status);
      return;
    }
    const fileData = await getResp.json();
    const sha = fileData.sha;
    const currentContent = atob(fileData.content.replace(/\n/g, ''));

    // Step 2: Replace only the cron line
    const cronRegex = /- cron:\s*'[^']*'/;
    if (!cronRegex.test(currentContent)) {
      toast('❌ Could not find cron line in workflow file', 'red');
      if (log) log.textContent = '❌ Workflow file missing cron line. Re-upload the fixed nifty100.yml first.';
      return;
    }

    const newContent = currentContent.replace(cronRegex, "- cron: '" + cron + "'");

    // Step 3: Push updated file
    const body = {
      message: 'Update schedule to: ' + cron + ' (IST ' + document.getElementById('schdisp').textContent + ')',
      content: btoa(unescape(encodeURIComponent(newContent))),
      sha: sha
    };

    const putResp = await fetch(apiUrl, {
      method: 'PUT',
      headers,
      body: JSON.stringify(body)
    });

    if (putResp.ok) {
      toast('✅ Schedule updated! Next run: ' + document.getElementById('schdisp').textContent + ' IST', 'green');
      if (log) log.textContent = '✅ Schedule applied: ' + cron + ' UTC\n   = ' + document.getElementById('schdisp').textContent + ' IST on ' + document.getElementById('schdays').textContent + '\n\n⚠️ Note: GitHub may delay first run by up to 15 minutes.';
    } else {
      const err = await putResp.json();
      toast('❌ Failed to update: ' + (err.message || putResp.status), 'red');
      if (log) log.textContent = '❌ GitHub error: ' + JSON.stringify(err);
    }
  } catch (e) {
    toast('❌ Network error: ' + e.message, 'red');
    if (log) log.textContent = '❌ Exception: ' + e.message;
  }
}


// ══════════════════════════════════════════════
// FIX 3: ENABLE WORKFLOW after GitHub pause
// This re-enables the workflow if it was auto-disabled
// ══════════════════════════════════════════════

// REPLACE your existing triggerWF() function with this:
async function triggerWF() {
  const gh = getGH();
  if (!gh.user || !gh.repo || !gh.token) {
    toast('⚠️ Configure GitHub settings first', 'yellow');
    pg('settings', null);
    return;
  }

  const btn = document.getElementById('runbtn');
  const st = document.getElementById('runst');
  const log = document.getElementById('actlog');
  const idx = document.getElementById('idx-sel').value;

  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="sp"></span> Sending...'; }
  if (st) st.textContent = 'Triggering workflow...';
  if (log) log.textContent = '▶ Triggering: ' + idx + '...';

  const headers = {
    'Authorization': 'token ' + gh.token,
    'Accept': 'application/vnd.github+json',
    'X-GitHub-Api-Version': '2022-11-28',
    'Content-Type': 'application/json'
  };

  // Step 1: Enable workflow first (in case GitHub auto-disabled it)
  try {
    await fetch(
      'https://api.github.com/repos/' + gh.user + '/' + gh.repo + '/actions/workflows/nifty100.yml/enable',
      { method: 'PUT', headers }
    );
  } catch(e) { /* ignore, might already be enabled */ }

  // Step 2: Dispatch workflow_dispatch event
  try {
    const r = await fetch(
      'https://api.github.com/repos/' + gh.user + '/' + gh.repo + '/actions/workflows/nifty100.yml/dispatches',
      {
        method: 'POST',
        headers,
        body: JSON.stringify({
          ref: 'main',
          inputs: { index_name: idx }
        })
      }
    );

    if (r.status === 204 || r.ok) {
      toast('✅ Sent! Check Telegram in ~30 seconds', 'green');
      if (st) st.textContent = '✅ Triggered at ' + new Date().toLocaleTimeString();
      if (log) log.textContent = '✅ Workflow triggered for: ' + idx + '\n\nExpect Telegram message in ~30 seconds.\n\nIf no message arrives:\n1. Check Actions tab on GitHub\n2. Check BOT_TOKEN and RECIPIENTS secrets\n3. Verify your Telegram bot is active';
      setTimeout(fetchRuns, 8000);
    } else {
      let msg = r.status;
      try { const j = await r.json(); msg = j.message || msg; } catch(e) {}
      toast('❌ Failed: ' + msg, 'red');
      if (st) st.textContent = '❌ Error: ' + msg;
      if (log) log.textContent = '❌ Trigger failed: HTTP ' + r.status + '\n' + msg + '\n\nCheck:\n- PAT token has "workflow" scope\n- Workflow file exists in .github/workflows/';
    }
  } catch(e) {
    toast('❌ Network error: ' + e.message, 'red');
    if (log) log.textContent = '❌ Exception: ' + e.message;
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '▶ Send to Telegram Now'; }
  }
}
